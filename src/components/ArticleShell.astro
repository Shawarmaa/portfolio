---
import type { ImageMetadata, MarkdownHeading } from "astro"
import { Image } from "astro:assets"
import { ArrowUpRight } from "lucide-astro"
import Breadcrumbs from "@/components/Breadcrumbs.astro"
import { Toc } from "@/components/Toc"

interface Crumb {
  label: string
  href?: string
}

interface Props {
  breadcrumb: Crumb[]
  title: string
  date?: string
  summary?: string
  hero?: ImageMetadata
  links?: { label: string; href: string }[]
  headings: MarkdownHeading[]
}

const { breadcrumb, title, date, summary, hero, links, headings } = Astro.props
---

<div
  class="mx-auto max-w-[640px] px-6 pt-20 pb-16 sm:pt-28 sm:pb-24 xl:grid xl:max-w-[96rem] xl:grid-cols-[1fr_minmax(0,640px)_1fr] xl:gap-8 xl:px-8"
>
  <!-- Left margin: breadcrumb + TOC, sticky. Shown on wide screens only.
       The TOC self-hides when there are no headings. -->
  <aside class="hidden xl:block">
    <div class="sticky top-10">
      <!-- h-7 matches the title's line-box so the breadcrumb aligns with it. -->
      <Breadcrumbs class="mb-6 flex h-7 items-center" items={breadcrumb} />
      <Toc headings={headings} client:idle />
    </div>
  </aside>

  <!-- xl:px-6 keeps the text column the same width/position as the home page
       (640px with 24px inset), so titles align across pages. -->
  <div class="min-w-0 xl:px-6">
    <Breadcrumbs class="mb-10 xl:hidden" items={breadcrumb} />

    <header class="mb-10">
      <h1 class="text-xl font-semibold tracking-tight">{title}</h1>
      {date && <p class="text-muted-foreground mt-2 text-sm">{date}</p>}
      {
        summary && (
          <p class="text-muted-foreground mt-6 text-lg leading-relaxed">
            {summary}
          </p>
        )
      }
      {
        links && links.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2">
            {links.map((l) => (
              <a
                href={l.href}
                target={l.href.startsWith("http") ? "_blank" : undefined}
                rel={
                  l.href.startsWith("http") ? "noopener noreferrer" : undefined
                }
                class="text-foreground hover:text-brand inline-flex items-center gap-1 text-sm transition-colors"
              >
                {l.label}
                <ArrowUpRight class="size-3.5" aria-hidden="true" />
              </a>
            ))}
          </div>
        )
      }
    </header>

    {
      hero && (
        <div class="bg-muted/40 mb-12 overflow-hidden rounded-xl">
          <Image src={hero} alt={title} class="w-full" />
        </div>
      )
    }

    <div class="prose">
      <slot />
    </div>
  </div>
</div>
