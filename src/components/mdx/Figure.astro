---
import { Image } from "astro:assets"
import type { ImageMetadata } from "astro"

interface Props {
  src: ImageMetadata | string
  alt: string
  caption?: string
  /* Let the figure bleed wider than the prose column on large screens. */
  wide?: boolean
}

const { src, alt, caption, wide = false } = Astro.props
const isImported = typeof src !== "string"
---

<figure class={`my-8 ${wide ? "lg:-mx-24" : ""}`}>
  <div class="bg-muted/40 overflow-hidden rounded-xl">
    {
      isImported ? (
        <Image
          src={src as ImageMetadata}
          alt={alt}
          class="w-full"
        />
      ) : (
        <img src={src as string} alt={alt} loading="lazy" class="w-full" />
      )
    }
  </div>
  {
    caption && (
      <figcaption class="text-muted-foreground mt-3 text-center text-sm">
        {caption}
      </figcaption>
    )
  }
</figure>
