---
import "@/styles/global.css"
import { ClientRouter } from "astro:transitions"
import { site } from "@/config"

interface Props {
  title?: string
  description?: string
  /* Path to an OG image in /public, or an absolute URL. */
  ogImage?: string
}

const { title, description = site.description, ogImage } = Astro.props

const pageTitle = title ? `${title} · ${site.name}` : site.name
const canonical = new URL(Astro.url.pathname, Astro.site)
// Only set a share image when the page supplies one (e.g. an article hero).
const ogUrl = ogImage ? new URL(ogImage, Astro.site) : undefined
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="256x256" href="/favicon-256.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <ClientRouter />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    {ogUrl && <meta property="og:image" content={ogUrl} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogUrl && <meta name="twitter:image" content={ogUrl} />}

    <!-- Dark by default, set before paint to avoid a flash. Press "d" to toggle. -->
    <script is:inline>
      ;(() => {
        const root = document.documentElement
        // Re-applied on astro:after-swap because client-side routing resets
        // <html>'s class to the new page's static markup (which has no .dark).
        const apply = () => {
          let dark = true
          try {
            dark = localStorage.getItem("theme") !== "light"
          } catch (e) {}
          root.classList.toggle("dark", dark)
        }
        apply()
        document.addEventListener("astro:after-swap", apply)
        addEventListener("keydown", (e) => {
          if (e.key !== "d" || e.metaKey || e.ctrlKey || e.altKey) return
          const t = e.target
          if (
            t &&
            (t.tagName === "INPUT" ||
              t.tagName === "TEXTAREA" ||
              t.isContentEditable)
          )
            return
          const dark = root.classList.toggle("dark")
          try {
            localStorage.setItem("theme", dark ? "dark" : "light")
          } catch (e) {}
        })
      })()
    </script>
  </head>
  <body class="overflow-x-clip">
    <slot />
  </body>
</html>
